generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GuildConfig {
  guildId   String   @id
  data      Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model GuildStats {
  guildId             String   @id
  todayKey            String?
  ticketsCreatedToday Int      @default(0)
  ticketsClosedToday  Int      @default(0)
  staff               Json?
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
}

model BotState {
  id        String   @id @default("singleton")
  guildIds  Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Whitelist {
  id        String   @id @default("singleton")
  enabled   Boolean  @default(false)
  guildIds  Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Transcript {
  id        String   @id @default(cuid())
  slug      String   @unique
  guildId   String // <-- ADICIONA ISSO
  guildSlug String?
  userId    String
  shortcode String
  html      String
  passHash  String
  expireAt  DateTime
  createdAt DateTime @default(now())

  @@index([guildId])
  @@index([guildSlug])
  @@index([userId])
  @@index([expireAt])
}

model Plan {
  key            String @id
  name           String
  description    String
  priceCents     Int     @default(0)
  active         Boolean @default(true)

  maxGuilds          Int  @default(1)
  maxTicketsPerMonth Int?
  maxTicketPanels    Int  @default(1)

  dashboardEnabled Boolean @default(true)
  paymentsEnabled  Boolean @default(false)
  safePayEnabled   Boolean @default(false)
  aiEnabled        Boolean @default(false)
  analyticsEnabled Boolean @default(false)
  prioritySupport  Boolean @default(false)

  subscriptions Subscription[]
  licenseKeys   LicenseKey[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  planKey   String
  status    String   @default("active") // scheduled | trialing | active | past_due | canceled | expired
  startedAt DateTime?
  renewAt   DateTime?
  expiresAt DateTime?
  canceledAt DateTime?
  cancelAtPeriodEnd Boolean @default(false)
  endedAt DateTime?
  statusReason String?
  lastStatusChangeAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan Plan @relation(fields: [planKey], references: [key])

  @@index([planKey])
  @@index([status])
  @@index([expiresAt])
  @@index([startedAt])
}

model LicenseKey {
  id             String   @id @default(cuid())
  codeHash       String   @unique
  codePrefix     String
  codeLast4      String
  planKey        String
  durationDays   Int      @default(30)
  maxActivations Int      @default(1)
  usedCount      Int      @default(0)
  status         String   @default("active") // active | disabled | exhausted | expired
  expiresAt      DateTime?
  note           String?
  createdBy      String?
  revokedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  plan        Plan                @relation(fields: [planKey], references: [key])
  activations LicenseActivation[]

  @@index([planKey])
  @@index([status])
  @@index([expiresAt])
}

model LicenseActivation {
  id          String   @id @default(cuid())
  keyId        String
  userId       String
  guildId      String?
  activatedAt  DateTime @default(now())
  startsAt     DateTime
  expiresAt    DateTime
  status       String   @default("active") // active | revoked
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  key LicenseKey @relation(fields: [keyId], references: [id], onDelete: Cascade)

  @@unique([keyId, userId, guildId])
  @@index([userId])
  @@index([guildId])
  @@index([expiresAt])
  @@index([status])
}

model GuildOwner {
  guildId   String   @id
  ownerId   String // discord user id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model UsageMonthly {
  id        String   @id @default(cuid())
  userId    String // dono (discord user id)
  monthKey  String // "2026-02" (UTC)
  tickets   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, monthKey])
  @@index([userId])
}

model GuildAiConfig {
  guildId        String  @id
  enabled        Boolean @default(false)

  // configuração prática
  persona        String  @default("")   // personalidade / tom
  rules          String  @default("")   // regras extras (o que pode/não pode)
  knowledgeText  String  @default("")   // FAQ/KB texto
  escalationMode String  @default("staffRole") // staffRole | logsChannel | custom
  escalationRoleId String? // opcional
  escalationChannelId String? // opcional

  // limite de memória
  memoryMaxMessages Int @default(20)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model TicketAiMessage {
  id        String @id @default(cuid())
  guildId   String
  channelId String
  authorId  String
  role      String // "user" | "assistant" | "staff"
  content   String
  createdAt DateTime @default(now())

  @@index([guildId, channelId, createdAt])
}

model GuildAIConfig {
  guildId   String   @id
  enabled   Boolean  @default(false)
  apiKey    String?
  model     String?  // ex: "openai/gpt-oss-120b" ou "llama-3.1-8b-instant"
  prompt    String?  // prompt “principal” do atendente
  staffRoleId String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([enabled])
}

model TicketAIMessage {
  id        String   @id @default(cuid())
  guildId   String
  channelId String
  role      String   // "user" | "assistant" | "system"
  content   String
  createdAt DateTime @default(now())

  @@index([guildId])
  @@index([channelId])
  @@index([createdAt])
}

model TicketAIMemory {
  channelId      String   @id
  guildId        String
  summary        String   @default("")
  lastSummaryAt  DateTime?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@index([guildId])
}

model AdminResetAudit {
  id        String   @id @default(cuid())
  adminId   String
  targets   Json
  result    Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}
